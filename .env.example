# =============================================================================
# Academic AI Workflow Assistant - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual API keys.
# NEVER commit your .env file to version control.

# --- LLM Provider ---
# Choose either "anthropic" or "openai"
LLM_PROVIDER=anthropic

# Anthropic (Claude) — used if LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# OpenAI (GPT-4o) — used if LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# --- Search Provider ---
# Choose either "tavily" or "serpapi"
SEARCH_PROVIDER=tavily

# Tavily API — recommended for academic search
TAVILY_API_KEY=your_tavily_api_key_here

# SerpAPI — fallback search provider
SERPAPI_API_KEY=your_serpapi_api_key_here

# --- App Settings ---
# Max tokens for LLM responses
MAX_TOKENS=4096

# Chunk size for PDF splitting (in characters)
CHUNK_SIZE=2000

# Chunk overlap for PDF splitting
CHUNK_OVERLAP=200

# Number of search results to return
SEARCH_RESULT_COUNT=5
